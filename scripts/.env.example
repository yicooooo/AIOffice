# OpenAI-compatible endpoint, e.g. Qwen or Kimi
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_API_KEY=your_api_key_here
MODEL_NAME=your_model_name_here

# Optional web-search provider:
# If SERPER_API_KEY is set, tool web_search will use Serper(Google).
# Otherwise it falls back to DuckDuckGo/Bing.
# Jina Search is optional and requires JINA_SEARCH_API_KEY.
SERPER_API_KEY=
WEB_TIMEOUT_SECONDS=20
WEB_HTTP_RETRIES=2
WEB_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
# Wikimedia APIs may require an identifiable UA.
WIKIMEDIA_USER_AGENT=AgentIF-ReAct/1.0 (contact: your_email@example.com)
# Fallback reader mirror for blocked or weak pages (e.g., 403 / JS-heavy pages)
ENABLE_JINA_FALLBACK=true
JINA_READER_BASE=https://r.jina.ai
# Optional authenticated Jina Search provider (https://s.jina.ai)
JINA_SEARCH_API_KEY=
MIN_BROWSE_TEXT_CHARS=300
# SEC may reject generic UA. Put identifiable value if needed:
# SEC_USER_AGENT=YourName YourOrg your_email@example.com
SEC_USER_AGENT=
ENABLE_OCR=true

# Evaluation mode
MAX_STEPS=20
STRICT_EVAL=false
LLM_ONLY_MODE=false
# Optional hard-disable for task-specific deterministic repair paths.
DISABLE_TASK_SPECIFIC_REPAIR=0
RESCUE_TURNS=3
